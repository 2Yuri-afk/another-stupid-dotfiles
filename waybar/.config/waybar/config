{
  "layer": "top",
  "position": "top",
  "height": 30,
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,
  "spacing": 8,
  "modules-left": [
    "clock",
    "cpu",
    "memory",
    "power-profiles-daemon",
    "hyprland/window"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "bluetooth",
    "network",
    "battery",
    "custom/screenshot",
    "custom/power"
  ],
  "custom/power": {
    "format": "pwr",
    "on-click": "~/.config/rofi/applets/bin/powermenu.sh",
    "tooltip": "Power Menu"
  },
  "custom/screenshot": {
    "format": "scr",
    "on-click": "~/.config/rofi/applets/bin/screenshot.sh",
    "tooltip": "Screenshot"
  },
  "hyprland/workspaces": {
    "disable-scroll": false,
    "all-outputs": true,
    "format": "{name}",
    "on-click": "activate",
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5,
        6
      ]
    }
  },
  "network": {
    "format-wifi": "net: {essid}",
    "format-ethernet": "eth: {ifname}",
    "tooltip-format": "{essid} ({signalStrength}%)",
    "format-linked": "net: on",
    "format-disconnected": "net: off",
    "interval": 1,
    "on-click": "kitty --title impala -e impala"
  },
  "battery": {
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "batt: {capacity}%",
    "format-charging": "batt: {capacity}%+",
    "interval": 1,
    "tooltip": false,
    "on-update": "~/.config/waybar/scripts/battery-notify.sh"
  },
  "pulseaudio": {
    "format": "vol: {volume}%",
    "format-muted": "vol: mute",
    "on-click-right": "pavucontrol -t 3",
    "on-click": "pactl -- set-sink-mute 0 toggle",
    "on-scroll-up": "pactl -- set-sink-volume 0 +5%",
    "on-scroll-down": "pactl -- set-sink-volume 0 -5%",
    "tooltip": false
  },
  "memory": {
    "format": "ram: {percentage}%",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "{used:0.1f}G/{total:0.1f}G"
  },
  "cpu": {
    "format": "cpu: {usage}%",
    "interval": 5,
    "tooltip": false
  },
  "power-profiles-daemon": {
    "format": "ppd: {profile}",
    "tooltip": false
  },
  "hyprland/window": {
    "format": "{}",
    "separate-outputs": true,
    "max-length": 30,
    "rewrite": {
      "^$": "yuri@yuri-arch"
    }
  },
  "clock": {
    "interval": 1,
    "timezone": "Asia/Manila",
    "format": "{:%A, %B %d  %I:%M:%S %p}",
    "tooltip": true,
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#548B84'><b>{}</b></span>",
        "weekdays": "<span color='#89A3BC'><b>{}</b></span>",
        "today": "<span color='#BD7B45'><b>{}</b></span>"
      }
    }
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10,
    "show-passive-items": true
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "bri: {percent}%",
    "tooltip": false,
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "bluetooth": {
    "format": "bt: on",
    "format-disabled": "bt: off",
    "format-off": "bt: off",
    "format-on": "bt: on",
    "format-connected": "bt: {device_alias}",
    "on-click": "kitty --title bluetuith -e bluetuith",
    "on-click-right": "blueman-manager",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected"
  }
}